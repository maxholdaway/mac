#!/bin/sh
# =============================================================================
# Laptop Setup Script
# Download: curl --remote-name https://raw.githubusercontent.com/maxholdaway/mac/refs/heads/main/install
# Run: sh install 2>&1 | tee ~/Desktop/laptop.log
# =============================================================================

set -e  # Exit on error

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log()     { echo -e "${GREEN}▶ $1${NC}"; }
warn()    { echo -e "${YELLOW}⚠ $1${NC}"; }
info()    { echo -e "${CYAN}  $1${NC}"; }
section() {
  echo -e "\n${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${BLUE}  $1${NC}"
  echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

install_cask() {
  if brew list --cask "$1" &>/dev/null; then
    log "Already installed (cask): $1"
  else
    log "Installing $1..."
    brew install --cask "$1" || warn "Failed to install cask: $1 — skipping"
  fi
}

install_formula() {
  if brew list "$1" &>/dev/null; then
    log "Already installed: $1"
  else
    log "Installing $1..."
    brew install "$1" || warn "Failed to install formula: $1 — skipping"
  fi
}

# =============================================================================
# HOMEBREW
# =============================================================================
section "Homebrew"

if ! command -v brew &>/dev/null; then
  log "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
else
  log "Homebrew already installed — updating..."
  brew update
fi

# Add Homebrew to PATH for this session (critical on Apple Silicon)
if [[ "$(uname -m)" == "arm64" ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
else
  eval "$(/usr/local/bin/brew shellenv)"
fi

# Persist Homebrew PATH in .zshrc
BREW_SHELLENV='eval "$($(brew --prefix)/bin/brew shellenv)"'
if ! grep -qF "$BREW_SHELLENV" ~/.zshrc 2>/dev/null; then
  printf '\n# Homebrew\n%s\n' "$BREW_SHELLENV" >> ~/.zshrc
fi

# =============================================================================
# HOMEBREW TAPS
# =============================================================================
section "Taps"

TAPS=(
  fluxcd/tap            # flux
  warrensbox/tap        # tfswitch
  johanhaleby/kubetail  # kubetail
  hashicorp/tap         # terraform, vault
  tokiwong/tap          # helm-switcher
  radiusmethod/awsd     # awsd
)

for tap in "${TAPS[@]}"; do
  brew tap "$tap" 2>/dev/null || true
done

# =============================================================================
# DESKTOP APPS (Casks)
# =============================================================================
section "Desktop Apps"

info "Productivity & Communication"
install_cask "1password"
install_cask "rectangle"       # Window manager
install_cask "superlist"       # Task manager
install_cask "miro"
install_cask "slack"
install_cask "discord"
install_cask "whatsapp"
install_cask "zoom"
install_cask "sonos"
install_cask "spotify"
install_cask "dropbox"

info "Dev Tools"
install_cask "visual-studio-code"
install_cask "ghostty"         # Fast, GPU-accelerated terminal
install_cask "warp"            # AI terminal
install_cask "docker-desktop"
install_cask "postman"
install_cask "yaak"            # API client (REST/GraphQL/gRPC)
install_cask "proxyman"        # HTTP debugging proxy
install_cask "figma"
install_cask "chrome-devtools"

info "AI Apps"
install_cask "claude"
install_cask "claude-code"
install_cask "codex"
install_cask "chatgpt"

info "Database & Data"
install_cask "dbeaver-community"
install_cask "tableplus"
install_cask "medis"           # Redis GUI

info "Cloud & Infrastructure"
install_cask "gcloud-cli"
install_cask "kube-forwarder"

info "Browsers"
install_cask "google-chrome"
install_cask "firefox"
install_cask "arc"

info "Networking & Security"
install_cask "tailscale"
install_cask "tripmode"

info "Files & Transfer"
install_cask "transmit"        # SFTP/S3 file transfer

info "Fonts"
install_cask "font-hack-nerd-font"
install_cask "font-meslo-lg-nerd-font"

info "Mobile / Flutter"
install_cask "flutter"

# =============================================================================
# LANGUAGES & RUNTIMES
# =============================================================================
section "Languages & Runtimes"

info "Go"
install_formula "go"
install_formula "protoc-gen-go"
install_formula "protobuf"

info "Python"
install_formula "pyenv"
install_formula "python"

# =============================================================================
# KUBERNETES & CLOUD
# =============================================================================
section "Kubernetes & Cloud"

install_formula "kubernetes-cli"     # kubectl
install_formula "kubectx"            # kubectx + kubens
install_formula "kubetail"           # Multi-pod log tailing
install_formula "k9s"                # K8s TUI
install_formula "helm"
install_formula "helm-switcher"      # Manage multiple helm versions
install_formula "fluxcd/tap/flux"
install_formula "k6"                 # Load testing

# =============================================================================
# AWS
# =============================================================================
section "AWS"

install_formula "awscli"
install_formula "aws-iam-authenticator"
install_formula "awsd"               # AWS profile switcher (shell-based)

# =============================================================================
# INFRASTRUCTURE & DEVOPS
# =============================================================================
section "Infrastructure & DevOps"

install_formula "warrensbox/tap/tfswitch"    # Terraform version switcher
install_formula "hashicorp/tap/terraform"    # Terraform (direct, for one-off use without tfswitch)
install_formula "hashicorp/tap/vault"        # HashiCorp Vault CLI
install_formula "flyctl"                     # Fly.io
install_formula "cloudflared"                # Cloudflare Tunnel
install_formula "fluxctl"                    # Flux v1 CLI (imperative control)

# =============================================================================
# MESSAGING & DATA
# =============================================================================
section "Messaging & Data"

install_formula "kafka"
install_formula "kaf"        # Kafka CLI client
install_formula "rabbitmq"
install_formula "redis"

# =============================================================================
# NODE.JS (via nvm — do NOT brew install node directly)
# =============================================================================
section "Node.js via nvm"

install_formula "nvm"
install_formula "yarn"
install_formula "pnpm"

# Source nvm for this session
export NVM_DIR="$HOME/.nvm"
[ -s "$(brew --prefix nvm)/nvm.sh" ] && source "$(brew --prefix nvm)/nvm.sh"

# Add nvm to .zshrc if not already present
if ! grep -q "NVM_DIR" ~/.zshrc 2>/dev/null; then
  cat >> ~/.zshrc << 'EOF'

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$(brew --prefix nvm)/nvm.sh" ] && source "$(brew --prefix nvm)/nvm.sh"
[ -s "$(brew --prefix nvm)/etc/bash_completion.d/nvm" ] && source "$(brew --prefix nvm)/etc/bash_completion.d/nvm"
EOF
fi

NODE_VERSION="22"   # Current LTS — switch with: nvm install <ver> && nvm alias default <ver>
log "Installing Node $NODE_VERSION (LTS)..."
nvm install "$NODE_VERSION"
nvm use "$NODE_VERSION"
nvm alias default "$NODE_VERSION"


# =============================================================================
# GLOBAL NPM PACKAGES
# =============================================================================
section "Global npm Packages"

NPM_GLOBALS=(
  @vue/cli              # Vue project scaffolding
  @anthropic-ai/claude-code  # Claude Code CLI
)

for pkg in "${NPM_GLOBALS[@]}"; do
  if npm list -g "$pkg" &>/dev/null; then
    log "Already installed globally: $pkg"
  else
    log "Installing npm global: $pkg"
    npm install -g "$pkg"
  fi
done


# =============================================================================
# GO TOOLS
# =============================================================================
section "Go Tools"

log "Installing Go tools..."
go install google.golang.org/grpc/cmd/protoc-gen-go-grpc@latest
go install github.com/securego/gosec/v2/cmd/gosec@latest
go install github.com/google/pprof@latest

install_formula "golangci-lint"
install_formula "golang-migrate"


# =============================================================================
# CLI & DEVELOPER EXPERIENCE
# =============================================================================
section "CLI & Developer Experience"

# Search & navigation
install_formula "fzf"
install_formula "ripgrep"               # rg — faster grep
install_formula "the_silver_searcher"   # ag — grep (legacy compat)

# Git
install_formula "git"
install_formula "git-lfs"
install_formula "gh"                    # GitHub CLI

# Shell prompt & UX
install_formula "zsh-autosuggestions"
install_formula "zsh-syntax-highlighting"

# Utilities
install_formula "jq"                    # JSON processor
install_formula "jwt-cli"               # Decode/inspect JWTs
install_formula "imagemagick"           # Image manipulation
install_formula "graphviz"              # Graph visualization
install_formula "hugo"                  # Static site generator
install_formula "terminal-notifier"     # macOS notifications from scripts
install_formula "youtube-dl"            # Media downloader

# =============================================================================
# GHOSTTY TERMINAL CONFIGURATION
# =============================================================================
section "Ghostty Terminal"

GHOSTTY_CONFIG_DIR="$HOME/.config/ghostty"
GHOSTTY_CONFIG="$GHOSTTY_CONFIG_DIR/config"

mkdir -p "$GHOSTTY_CONFIG_DIR"

if [[ -f "$GHOSTTY_CONFIG" ]]; then
  log "Ghostty config already exists — skipping (edit at ~/.config/ghostty/config)"
else
  log "Writing Ghostty config..."
  cat > "$GHOSTTY_CONFIG" << 'EOF'
# =============================================================
# Ghostty Configuration
# Docs: https://ghostty.org/docs/config
# =============================================================

# --- Font ---
font-family = "MesloLGS Nerd Font Mono"
font-size = 18

# --- Theme ---
theme = dark:catppuccin-mocha,light:catppuccin-latte

# --- Window ---
window-padding-x = 12
window-padding-y = 10
window-decoration = true

# --- Tabs & splits ---
macos-option-as-alt = true     # Enables alt/option key combos in shell

# --- Cursor ---
cursor-style = block
cursor-style-blink = true
cursor-color = #f8f8f2

# --- Shell ---
shell-integration = detect
shell-integration-features = cursor,sudo,title

# Misc
mouse-hide-while-typing = true
clipboard-read = allow
clipboard-write = allow

# --- Scrollback ---
scrollback-limit = 10000

# --- Performance ---
window-vsync = true

# --- Key bindings ---
# Open new tab:        Cmd+T  (default)
# Split right:        Cmd+D
# Split down:         Cmd+Shift+D
# Close pane/tab:     Cmd+W  (default)
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+shift+enter=toggle_fullscreen
EOF
  log "Ghostty config written to $GHOSTTY_CONFIG"
fi

# =============================================================================
# SHELL CONFIGURATION (.zshrc)
# =============================================================================
section "Shell Configuration"

# zsh-autosuggestions
if ! grep -q "zsh-autosuggestions" ~/.zshrc 2>/dev/null; then
  printf '\n# zsh plugins\n' >> ~/.zshrc
  echo "source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh" >> ~/.zshrc
fi

# zsh-syntax-highlighting (must be sourced last)
if ! grep -q "zsh-syntax-highlighting" ~/.zshrc 2>/dev/null; then
  echo "source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" >> ~/.zshrc
fi

# fzf shell integration
if ! grep -q 'source.*fzf' ~/.zshrc 2>/dev/null; then
  "$(brew --prefix fzf)/install" --all --no-bash --no-fish 2>/dev/null || true
fi

# pyenv
if ! grep -q 'pyenv init' ~/.zshrc 2>/dev/null; then
  cat >> ~/.zshrc << 'EOF'

# pyenv
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init -)"
EOF
fi

# =============================================================================
# GIT CONFIGURATION
# =============================================================================
section "Git Configuration"

# Prompt for identity if not already set
if [[ -z "$(git config --global user.name)" ]]; then
  echo -n "Enter your full name for Git: "
  read git_name
  git config --global user.name "$git_name"
fi

if [[ -z "$(git config --global user.email)" ]]; then
  echo -n "Enter your email for Git: "
  read git_email
  git config --global user.email "$git_email"
fi

# Defaults
git config --global init.defaultBranch main
git config --global fetch.prune true
git config --global core.autocrlf input
git config --global core.editor nano

# Global gitignore
git config --global core.excludesfile ~/.gitignore_global

# SSH URL rewrites (avoids HTTPS for known hosts)
git config --global url."git@github.com:".insteadOf    "https://github.com/"
git config --global url."git@gitlab.com:".insteadOf    "https://gitlab.com/"
git config --global url."git@bitbucket.org:".insteadOf "https://bitbucket.org/"

# Merge tool (Sourcetree)
git config --global mergetool.sourcetree.cmd \
  '/Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh "$LOCAL" "$REMOTE" -ancestor "$BASE" -merge "$MERGED"'
git config --global mergetool.sourcetree.trustExitCode true

# GPG signing via SSH key
git config --global gpg.format ssh
git config --global commit.gpgsign true
git config --global tag.gpgsign true
git config --global gpg.ssh.allowedSignersFile ~/.config/git/allowed_signers

# git-lfs
git config --global filter.lfs.required true
git config --global filter.lfs.clean    "git-lfs clean -- %f"
git config --global filter.lfs.smudge   "git-lfs smudge -- %f"
git config --global filter.lfs.process  "git-lfs filter-process"

# Create allowed_signers file if it doesn't exist
# Remember to populate afterwards
mkdir -p ~/.config/git
touch ~/.config/git/allowed_signers


# =============================================================================
# MACOS DEFAULTS
# =============================================================================
section "macOS Defaults"

log "Applying sensible macOS defaults..."

# Finder
defaults write com.apple.finder AppleShowAllFiles YES
defaults write NSGlobalDomain AppleShowAllExtensions -bool true
defaults write com.apple.finder ShowPathbar -bool true
defaults write com.apple.finder ShowStatusBar -bool true
defaults write com.apple.finder _FXSortFoldersFirst -bool true

# Disable app quarantine dialog
defaults write com.apple.LaunchServices LSQuarantine -bool false

# Dock: don't auto-hide, no recent apps
defaults write com.apple.dock autohide -bool false
defaults write com.apple.dock show-recents -bool false

# Battery percentage in menu bar
defaults write com.apple.menuextra.battery ShowPercent YES

# --- Trackpad ---
log "Configuring trackpad..."

defaults write -g com.apple.swipescrolldirection -bool false

# Tap to click
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad Clicking -bool true
defaults write com.apple.AppleMultitouchTrackpad Clicking -bool true

# Tracking speed (0–3, where 3 is fastest)
defaults write -g com.apple.trackpad.scaling -float 2.2

# --- Keyboard ---
log "Configuring keyboard..."

# Key repeat: fast (run capture-settings.sh on source machine to get your exact values)
defaults write NSGlobalDomain KeyRepeat -int 1
defaults write NSGlobalDomain InitialKeyRepeat -int 15

# --- Input Languages ---
log "Configuring input sources..."

# US International - PC + Swedish
defaults write com.apple.HIToolbox AppleEnabledInputSources -array \
  '<dict><key>Bundle ID</key><string>com.apple.keylayout.USInternational-PC</string><key>InputSourceKind</key><string>Keyboard Layout</string></dict>' \
  '<dict><key>Bundle ID</key><string>com.apple.keylayout.Swedish</string><key>InputSourceKind</key><string>Keyboard Layout</string></dict>'

defaults write com.apple.HIToolbox AppleCurrentKeyboardLayoutInputSourceID \
  "com.apple.keylayout.USInternational-PC"

# --- Keyboard Shortcuts ---
log "Configuring keyboard shortcuts..."
#
#   Option+Space → Spotlight search      (hotkey ID 64)
#   Cmd+Space    → Switch input language  (hotkey ID 60)
#
# Modifier flags: Cmd=1048576, Option=524288, Ctrl=262144, Shift=131072
# Space key code = 49, char code = 32

# Disable default Cmd+Space Spotlight (to free it for input switching)
defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys -dict-add 64 \
  '<dict><key>enabled</key><true/><key>value</key><dict><key>parameters</key><array><integer>32</integer><integer>49</integer><integer>524288</integer></array><key>type</key><string>standard</string></dict></dict>'

# Input source switch: Cmd+Space (hotkey 60)
defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys -dict-add 60 \
  '<dict><key>enabled</key><true/><key>value</key><dict><key>parameters</key><array><integer>32</integer><integer>49</integer><integer>1048576</integer></array><key>type</key><string>standard</string></dict></dict>'

# Disable hotkey 61 (Select next input source in menu — avoid conflict)
defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys -dict-add 61 \
  '<dict><key>enabled</key><false/><key>value</key><dict><key>parameters</key><array><integer>32</integer><integer>49</integer><integer>1572864</integer></array><key>type</key><string>standard</string></dict></dict>'

# Activate all settings changes (required for hotkeys to take effect without reboot)
/System/Library/PrivateFrameworks/SystemAdministration.framework/Resources/activateSettings -u 2>/dev/null || true

killall Finder 2>/dev/null || true
killall Dock 2>/dev/null || true

# =============================================================================
# DONE
# =============================================================================
section "✅ Setup Complete"